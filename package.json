{
  "name": "@rivium/web-chat",
  "version": "0.1.0",
  "description": "RiviumChat JavaScript/TypeScript SDK for web applications",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "chat",
    "rivium-chat",
    "messaging",
    "realtime",
    "websocket"
  ],
  "author": "Rivium <support@rivium.co>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rivium-co/rivium-chat-web-sdk.git"
  },
  "homepage": "https://rivium.co/cloud/rivium-chat",
  "dependencies": {
    "centrifuge": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.55.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
